<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= meta.title %></title>
  <meta name="description" content="<%= meta.description %>">
  <meta name="theme-color" content="#F5F0E8">
  <meta property="og:title" content="<%= meta.title %>">
  <meta property="og:description" content="<%= meta.description %>">
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= meta.url %>">
  <meta property="og:image" content="<%= meta.url %>images/hero.jpg">
  <link rel="canonical" href="<%= meta.url %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <script type="application/ld+json"><%- schema %></script>
</head>
<body class="bg-cream text-coal font-sans antialiased selection:bg-moss selection:text-cream">
  <div class="pointer-events-none fixed inset-0 z-[120] flex items-center justify-center bg-cream transition-opacity duration-500" data-loader>
    <div class="text-center">
      <p class="font-serif text-5xl md:text-6xl">Cuatro Cuartos</p>
      <p class="mt-3 text-[10px] uppercase tracking-editorial text-coal/65">Tonala, Jal.</p>
    </div>
  </div>

  <div class="pointer-events-none fixed left-0 top-0 z-[90] hidden h-6 w-6 -translate-x-1/2 -translate-y-1/2 rounded-full border border-coal/45 bg-cream/20 mix-blend-multiply lg:block" data-cursor></div>

  <a
    href="<%= `${whatsappBase}?text=${encodeURIComponent(showroomMessage)}` %>"
    target="_blank"
    rel="noreferrer"
    aria-label="Abrir WhatsApp"
    class="fixed bottom-5 right-5 z-[85] inline-flex h-14 w-14 items-center justify-center rounded-full bg-moss text-cream shadow-soft transition-transform duration-300 hover:scale-[1.04]"
  >
    <span class="text-xl">↗</span>
  </a>

  <header class="fixed inset-x-0 top-0 z-[80] px-4 py-4 md:px-8 lg:px-10">
    <div class="mx-auto flex max-w-[1680px] items-center justify-between border border-coal/10 bg-cream/70 px-5 py-4 transition-all duration-300 ease-editorial" data-navbar>
      <a href="#inicio" class="relative z-10">
        <span class="block font-serif text-2xl leading-none md:text-3xl">Cuatro Cuartos</span>
        <span class="mt-1 block text-[10px] uppercase tracking-editorial text-coal/65">Tonala, Jal.</span>
      </a>

      <nav class="hidden items-center gap-8 lg:flex">
        <% navigation.forEach((item) => { %>
          <a href="<%= item.href %>" class="text-[12px] uppercase tracking-editorial text-coal/78 transition-colors duration-300 hover:text-moss"><%= item.label %></a>
        <% }) %>
      </nav>

      <button class="relative z-10 inline-flex h-10 w-10 items-center justify-center rounded-full border border-coal/15 lg:hidden" type="button" data-menu-toggle aria-label="Abrir menu">
        <span class="space-y-1.5">
          <span class="block h-px w-5 bg-coal"></span>
          <span class="block h-px w-5 bg-coal"></span>
        </span>
      </button>
    </div>

    <div class="mx-auto mt-3 hidden max-w-[1680px] border border-coal/10 bg-cream/90 p-6 backdrop-blur-xl lg:hidden" data-mobile-menu>
      <nav class="flex flex-col gap-4">
        <% navigation.forEach((item) => { %>
          <a href="<%= item.href %>" class="text-sm uppercase tracking-editorial text-coal/75"><%= item.label %></a>
        <% }) %>
      </nav>
    </div>
  </header>

  <main id="inicio">
    <section class="relative flex min-h-screen items-end overflow-hidden" data-reveal>
      <div class="absolute inset-0">
        <img src="/images/hero.jpg" alt="Galeria de muebles de autor Cuatro Cuartos" class="hero-image h-full w-full object-cover">
        <div class="grain-overlay absolute inset-0"></div>
        <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(28,26,23,0.18)_0%,rgba(28,26,23,0.28)_42%,rgba(28,26,23,0.6)_100%)]"></div>
      </div>

      <div class="relative z-10 mx-auto flex w-full max-w-[1680px] flex-col gap-12 px-6 pb-12 pt-36 text-cream md:px-12 md:pb-16 lg:px-[120px] lg:pb-20">
        <div class="max-w-[820px]">
          <p class="reveal-item mb-4 text-[11px] uppercase tracking-editorial text-cream/70" style="--delay: 0s;">Galeria de diseno en Tonala</p>
          <h1 class="reveal-item max-w-[920px] font-serif text-[56px] leading-[0.92] sm:text-[72px] lg:text-[96px]" style="--delay: 0.15s;">
            Objetos que <br> sobreviven el tiempo.
          </h1>
          <p class="reveal-item mt-6 max-w-[560px] text-base leading-relaxed text-cream/85 md:text-lg" style="--delay: 0.3s;">
            Mobiliario de autor fabricado a mano en Tonala, Jalisco.
          </p>
          <div class="reveal-item mt-10 flex flex-wrap items-center gap-5" style="--delay: 0.45s;">
            <a href="#coleccion" class="inline-flex items-center gap-3 text-sm uppercase tracking-editorial text-cream link-underline">
              Explorar coleccion
              <span aria-hidden="true">→</span>
            </a>
            <a href="<%= `${whatsappBase}?text=${encodeURIComponent(showroomMessage)}` %>" target="_blank" rel="noreferrer" class="inline-flex items-center gap-3 text-sm uppercase tracking-editorial text-cream/78 transition-colors duration-300 hover:text-cream">
              Agendar visita al taller
            </a>
          </div>
        </div>

        <div class="reveal-item ml-auto grid max-w-[540px] grid-cols-2 gap-6 text-right text-[11px] uppercase tracking-editorial text-cream/70" style="--delay: 0.6s;">
          <span>Wabi-sabi x Jalisco</span>
          <span>Desde 2018</span>
        </div>
      </div>
    </section>

    <section class="section-fade mx-auto max-w-[1680px] px-6 py-20 md:px-12 lg:px-[120px] lg:py-28" data-reveal>
      <div class="grid gap-8 lg:grid-cols-[0.95fr,1.15fr] lg:items-start">
        <div class="max-w-[420px]">
          <p class="text-[11px] uppercase tracking-editorial text-coal/45">Posicionamiento</p>
          <h2 class="mt-4 font-serif text-4xl leading-tight md:text-5xl">No es una muebleria tipica de Tonala.</h2>
        </div>
        <div class="grid gap-6 text-base leading-8 text-coal/78 md:grid-cols-2">
          <p>Cuatro Cuartos opera como una galeria de diseno: piezas de escala domestica, lenguaje escultorico y materiales que envejecen con dignidad.</p>
          <p>La referencia no son los corredores de volumen; son las boutiques de CDMX, los estudios internacionales y la artesania jalisciense entendida como patrimonio vivo.</p>
        </div>
      </div>
    </section>

    <section id="coleccion" class="section-fade mx-auto max-w-[1680px] px-6 py-8 md:px-12 lg:px-[120px] lg:py-12" data-reveal>
      <div class="mb-12 flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-[11px] uppercase tracking-editorial text-coal/45">Coleccion</p>
          <h2 class="mt-4 max-w-[720px] font-serif text-4xl leading-tight md:text-6xl">Piezas para habitar el tiempo, no solo el espacio.</h2>
        </div>

        <div class="flex flex-col gap-6">
          <div class="flex flex-wrap gap-4 text-[12px] uppercase tracking-editorial text-coal/55">
            <button type="button" class="filter-chip is-active" data-filter="Todo">Todo</button>
            <button type="button" class="filter-chip" data-filter="Sala">Sala</button>
            <button type="button" class="filter-chip" data-filter="Comedor">Comedor</button>
            <button type="button" class="filter-chip" data-filter="Recámara">Recámara</button>
            <button type="button" class="filter-chip" data-filter="Iluminación">Iluminación</button>
          </div>
          <div class="flex flex-wrap gap-4 text-sm text-coal/65">
            <% materials.forEach((material) => { %>
              <span class="inline-flex items-center gap-3">
                <span class="h-3.5 w-3.5 rounded-full border border-coal/10" style="background-color: <%= material.color %>;"></span>
                <span><%= material.name %></span>
              </span>
            <% }) %>
          </div>
        </div>
      </div>

      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4" data-gallery>
        <% pieces.forEach((piece, index) => { %>
          <article
            class="gallery-card group relative overflow-hidden bg-cream-deep <%= piece.featured ? 'xl:col-span-2 xl:row-span-2' : '' %> <%= index === 5 ? 'md:col-span-2 xl:col-span-1' : '' %>"
            data-category="<%= piece.category %>"
            data-reveal
          >
            <span class="absolute left-5 top-5 z-20 text-[11px] uppercase tracking-editorial text-cream/85">— <%= piece.id %></span>
            <img src="<%= piece.image %>" alt="<%= piece.name %>" style="aspect-ratio: <%= piece.aspectRatio %>;" class="h-full w-full object-cover transition-transform duration-700 ease-editorial group-hover:scale-[1.03]">
            <div class="gallery-shade absolute inset-0 bg-[linear-gradient(180deg,rgba(28,26,23,0.02)_0%,rgba(28,26,23,0.72)_100%)] opacity-80 transition-opacity duration-500"></div>
            <div class="gallery-overlay absolute inset-x-0 bottom-0 z-20 translate-y-full p-6 text-cream transition-transform duration-500 ease-editorial group-hover:translate-y-0">
              <div class="flex items-end justify-between gap-4">
                <div>
                  <p class="text-[11px] uppercase tracking-editorial text-cream/72"><%= piece.category %></p>
                  <h3 class="mt-2 font-serif text-3xl"><%= piece.name %></h3>
                </div>
                <p class="text-sm text-cream/78"><%= piece.price %></p>
              </div>
              <div class="mt-5 grid gap-2 text-sm text-cream/78 md:grid-cols-2">
                <p><%= piece.material %></p>
                <p><%= piece.hours %></p>
                <p>Artesano: <%= piece.artisan %></p>
              </div>
              <a
                href="<%= `${whatsappBase}?text=${encodeURIComponent(piece.message)}` %>"
                target="_blank"
                rel="noreferrer"
                class="mt-6 inline-flex items-center gap-2 text-[12px] uppercase tracking-editorial text-cream link-underline"
              >
                Consultar pieza
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </article>
        <% }) %>
      </div>
    </section>

    <section id="proceso" class="section-fade mx-auto max-w-[1680px] px-6 py-20 md:px-12 lg:px-[120px] lg:py-28" data-reveal>
      <div class="mb-12 grid gap-8 lg:grid-cols-[0.9fr,1.1fr]">
        <div>
          <p class="text-[11px] uppercase tracking-editorial text-coal/45">El Proceso</p>
          <h2 class="mt-4 font-serif text-4xl leading-tight md:text-6xl">El objeto final conserva el rastro de cada decision.</h2>
        </div>
        <p class="max-w-[560px] justify-self-end text-base leading-8 text-coal/72">Cada pieza nace con ritmo lento, seleccion de materiales honestos y una fabricacion manual que acepta la variacion natural como parte de su belleza.</p>
      </div>

      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        <% processSteps.forEach((step, index) => { %>
          <article class="border border-coal/10 bg-cream px-6 py-8">
            <span class="text-[11px] uppercase tracking-editorial text-coal/40">0<%= index + 1 %></span>
            <div class="mt-8 flex h-12 w-12 items-center justify-center text-coal">
              <% if (step.icon === 'design') { %>
                <svg viewBox="0 0 48 48" class="h-10 w-10 fill-none stroke-current stroke-[1.2]">
                  <rect x="8" y="8" width="32" height="32" rx="2"></rect>
                  <path d="M16 32L32 16"></path>
                  <path d="M16 18h14v14"></path>
                </svg>
              <% } %>
              <% if (step.icon === 'selection') { %>
                <svg viewBox="0 0 48 48" class="h-10 w-10 fill-none stroke-current stroke-[1.2]">
                  <circle cx="24" cy="24" r="16"></circle>
                  <path d="M24 8v32"></path>
                  <path d="M8 24h32"></path>
                </svg>
              <% } %>
              <% if (step.icon === 'carving') { %>
                <svg viewBox="0 0 48 48" class="h-10 w-10 fill-none stroke-current stroke-[1.2]">
                  <path d="M12 36L36 12"></path>
                  <path d="M18 12h18v18"></path>
                  <path d="M12 28l8 8"></path>
                </svg>
              <% } %>
              <% if (step.icon === 'finish') { %>
                <svg viewBox="0 0 48 48" class="h-10 w-10 fill-none stroke-current stroke-[1.2]">
                  <path d="M24 10c6 6 10 11 10 17a10 10 0 1 1-20 0c0-6 4-11 10-17Z"></path>
                  <path d="M20 30c1.2 2 3 3 5.5 3"></path>
                </svg>
              <% } %>
            </div>
            <h3 class="mt-8 font-serif text-3xl"><%= step.title %></h3>
            <p class="mt-3 text-[11px] uppercase tracking-editorial text-terracotta"><%= step.duration %></p>
            <p class="mt-6 text-base leading-7 text-coal/72"><%= step.detail %></p>
          </article>
        <% }) %>
      </div>
    </section>

    <section id="filosofia" class="section-fade bg-cream-deep py-20 md:py-28" data-reveal>
      <div class="mx-auto grid max-w-[1680px] gap-10 px-6 md:px-12 lg:grid-cols-[1fr,0.85fr] lg:px-[120px]">
        <div>
          <p class="text-[11px] uppercase tracking-editorial text-coal/45">Filosofia Wabi-sabi</p>
          <blockquote class="mt-6 max-w-[760px] font-serif text-4xl italic leading-tight md:text-6xl">
            “La materia no se corrige para parecer perfecta; se escucha hasta encontrar su forma.”
          </blockquote>
          <div class="mt-10 grid max-w-[760px] gap-6 text-base leading-8 text-coal/72 md:grid-cols-2">
            <p>La filosofia wabi-sabi reconoce la belleza de lo incompleto, lo sobrio y lo que cambia con el tiempo. En Cuatro Cuartos eso se traduce en vetas abiertas, texturas honestas y acabados mates que no esconden la mano del taller.</p>
            <p>La artesania de Jalisco aporta profundidad material y tecnica. No como cita folclorica, sino como una forma contemporanea de construir objetos con memoria, peso y permanencia.</p>
          </div>
        </div>
        <div class="relative min-h-[420px] overflow-hidden">
          <img src="/images/gallery3.jpg" alt="Textura de madera y ceramica" class="h-full w-full object-cover">
          <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(28,26,23,0.08)_0%,rgba(28,26,23,0.45)_100%)]"></div>
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(245,240,232,0.16),transparent_52%)]"></div>
        </div>
      </div>
    </section>

    <section id="taller" class="section-fade mx-auto max-w-[1680px] px-6 py-20 md:px-12 lg:px-[120px] lg:py-28" data-reveal>
      <div class="relative overflow-hidden">
        <img src="/images/hero.jpg" alt="Panoramica del taller de Cuatro Cuartos" class="h-[580px] w-full object-cover">
        <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(28,26,23,0.68)_0%,rgba(28,26,23,0.32)_52%,rgba(28,26,23,0.1)_100%)]"></div>
        <div class="absolute inset-0 flex items-end p-8 text-cream md:p-12 lg:p-16">
          <div class="max-w-[620px]">
            <p class="text-[11px] uppercase tracking-editorial text-cream/70">El Taller</p>
            <h2 class="mt-4 font-serif text-4xl leading-tight md:text-6xl">La experiencia termina de entenderse frente a la materia.</h2>
            <p class="mt-5 max-w-[500px] text-base leading-8 text-cream/82">Visita el taller en Av. Tonaltecas 123, Tonala, Jalisco. Madera, piedra, ceramica y lino conviven en un espacio que funciona como estudio, archivo y sala de exhibicion.</p>
            <div class="mt-8 flex flex-wrap gap-4">
              <a href="<%= showroomMapUrl %>" target="_blank" rel="noreferrer" class="inline-flex items-center gap-3 border border-cream/35 px-5 py-3 text-[12px] uppercase tracking-editorial text-cream transition-colors duration-300 hover:bg-cream hover:text-coal">Ver en Google Maps</a>
              <a href="<%= `${whatsappBase}?text=${encodeURIComponent(showroomMessage)}` %>" target="_blank" rel="noreferrer" class="inline-flex items-center gap-3 bg-cream px-5 py-3 text-[12px] uppercase tracking-editorial text-coal transition-colors duration-300 hover:bg-terracotta hover:text-cream">Agendar visita al taller</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-fade mx-auto max-w-[1680px] px-6 py-20 md:px-12 lg:px-[120px] lg:py-24" data-reveal>
      <div class="mb-12 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-[11px] uppercase tracking-editorial text-coal/45">Testimonios</p>
          <h2 class="mt-4 font-serif text-4xl leading-tight md:text-5xl">Lo que permanece despues de la compra.</h2>
        </div>
        <p class="max-w-[420px] text-base leading-8 text-coal/70">Sin artificio comercial: solo la impresion de quienes viven con las piezas todos los dias.</p>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        <% testimonials.forEach((testimonial) => { %>
          <article class="border-t border-coal/20 pt-8">
            <p class="font-serif text-3xl italic leading-relaxed text-coal/88">“<%= testimonial.quote %>”</p>
            <p class="mt-8 text-[12px] uppercase tracking-editorial text-coal/50"><%= testimonial.author %> · <%= testimonial.city %></p>
          </article>
        <% }) %>
      </div>
    </section>
  </main>

  <footer id="footer" class="section-fade border-t border-coal/10 bg-[#e9dfd1] px-6 py-16 md:px-12 lg:px-[120px] lg:py-20" data-reveal>
    <div class="mx-auto grid max-w-[1680px] gap-10 lg:grid-cols-3">
      <div>
        <p class="font-serif text-4xl">Cuatro Cuartos</p>
        <p class="mt-5 max-w-[320px] text-base leading-8 text-coal/72">Objetos que sobreviven el tiempo. Tonala desde 2018.</p>
      </div>

      <div>
        <p class="text-[11px] uppercase tracking-editorial text-coal/45">Direccion y horarios</p>
        <address class="mt-5 not-italic text-base leading-8 text-coal/72">
          <p>Av. Tonaltecas 123</p>
          <p>Tonala, Jalisco, Mexico</p>
        </address>
        <div class="mt-5 text-base leading-8 text-coal/72">
          <% hours.forEach((slot, index) => { %>
            <p>
              <%= ['Lun', 'Mar', 'Mie', 'Jue', 'Vie', 'Sab'][index] %> · <%= slot.opens %> - <%= slot.closes %>
            </p>
          <% }) %>
        </div>
        <a href="<%= showroomMapUrl %>" target="_blank" rel="noreferrer" class="mt-6 inline-flex items-center gap-2 text-[12px] uppercase tracking-editorial text-coal link-underline">
          Google Maps
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div>
        <p class="text-[11px] uppercase tracking-editorial text-coal/45">Redes y contacto</p>
        <div class="mt-5 flex flex-col gap-3 text-base text-coal/72">
          <a href="https://instagram.com" target="_blank" rel="noreferrer" class="transition-colors duration-300 hover:text-moss">Instagram</a>
          <a href="https://facebook.com" target="_blank" rel="noreferrer" class="transition-colors duration-300 hover:text-moss">Facebook</a>
          <a href="<%= `${whatsappBase}?text=${encodeURIComponent(showroomMessage)}` %>" target="_blank" rel="noreferrer" class="transition-colors duration-300 hover:text-moss">WhatsApp</a>
        </div>
        <form class="mt-8 border-b border-coal/20 pb-3" action="#" method="post">
          <label for="newsletter" class="block text-[11px] uppercase tracking-editorial text-coal/45">Newsletter minimalista</label>
          <div class="mt-4 flex items-center gap-4">
            <input id="newsletter" type="email" placeholder="Tu correo" class="w-full bg-transparent text-base text-coal outline-none placeholder:text-coal/35">
            <button type="submit" class="text-[12px] uppercase tracking-editorial text-coal transition-colors duration-300 hover:text-moss">Enviar</button>
          </div>
        </form>
      </div>
    </div>
  </footer>

  <script>
    const loader = document.querySelector('[data-loader]');
    const cursor = document.querySelector('[data-cursor]');
    const navbar = document.querySelector('[data-navbar]');
    const menuToggle = document.querySelector('[data-menu-toggle]');
    const mobileMenu = document.querySelector('[data-mobile-menu]');
    const filterButtons = [...document.querySelectorAll('[data-filter]')];
    const galleryItems = [...document.querySelectorAll('[data-gallery] [data-category]')];
    const revealTargets = document.querySelectorAll('[data-reveal]');

    window.addEventListener('load', () => {
      setTimeout(() => {
        loader.classList.add('opacity-0');
        setTimeout(() => loader.remove(), 500);
      }, 1200);
    });

    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        navbar.classList.add('is-scrolled');
      } else {
        navbar.classList.remove('is-scrolled');
      }
    });

    if (menuToggle && mobileMenu) {
      menuToggle.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
      });

      mobileMenu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => mobileMenu.classList.add('hidden'));
      });
    }

    filterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const { filter } = button.dataset;
        filterButtons.forEach((item) => item.classList.remove('is-active'));
        button.classList.add('is-active');

        galleryItems.forEach((card) => {
          const matches = filter === 'Todo' || card.dataset.category === filter;
          card.classList.toggle('is-hidden', !matches);
        });
      });
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.16 });

    revealTargets.forEach((target) => observer.observe(target));

    if (cursor) {
      window.addEventListener('mousemove', (event) => {
        cursor.style.left = `${event.clientX}px`;
        cursor.style.top = `${event.clientY}px`;
      });

      document.querySelectorAll('a, button').forEach((node) => {
        node.addEventListener('mouseenter', () => cursor.classList.add('is-active'));
        node.addEventListener('mouseleave', () => cursor.classList.remove('is-active'));
      });
    }
  </script>
</body>
</html>
